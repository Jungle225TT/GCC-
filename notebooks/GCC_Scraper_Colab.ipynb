    "## Step 5 — 查看输出结果"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, glob\n",
    "\n",
    "output_dir = 'output'\n",
    "files = sorted(glob.glob(f'{output_dir}/*'), key=os.path.getmtime, reverse=True)\n",
    "\n",
    "print(f'output/ 目录下共 {len(files)} 个文件（按时间倒序）：\\n')\n",
    "for f in files:\n",
    "    size = os.path.getsize(f) / 1024\n",
    "    mtime = os.path.getmtime(f)\n",
    "    import datetime\n",
    "    t = datetime.datetime.fromtimestamp(mtime).strftime('%Y-%m-%d %H:%M')\n",
    "    print(f'  {t}  {size:6.0f} KB  {os.path.basename(f)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 在 Colab 中预览最新的 Markdown 简报\n",
    "import glob, os\n",
    "from IPython.display import Markdown, display\n",
    "\n",
    "md_files = sorted(glob.glob('output/gcc_summary_*.md'), key=os.path.getmtime, reverse=True)\n",
    "if md_files:\n",
    "    latest = md_files[0]\n",
    "    print(f'预览：{latest}\\n')\n",
    "    with open(latest, encoding='utf-8') as f:\n",
    "        display(Markdown(f.read()))\n",
    "else:\n",
    "    print('未找到 AI 简报文件，请先使用 --ai 参数运行抓取。')"
   ]
